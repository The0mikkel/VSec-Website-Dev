---
interface Props {
  listId: string;
  placeholder?: string;
}
const { listId, placeholder = 'Search...' } = Astro.props;
const uid = `sf-${listId}`;
---

<div class="mb-8 search-filter" id={uid} data-list-id={listId}>
  <div class="relative">
    <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-text-muted pointer-events-none" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
    </svg>
    <input
      type="text"
      id={`${uid}-input`}
      placeholder={placeholder}
      autocomplete="off"
      aria-label={placeholder}
      class="w-full font-mono text-sm bg-bg-elevated border border-border rounded-lg px-4 py-2.5 pl-9 pr-10 text-text-primary placeholder:text-text-muted focus:outline-none focus:border-accent/40 transition-colors duration-200"
    />
    <button
      id={`${uid}-clear`}
      class="absolute right-3 top-1/2 -translate-y-1/2 font-mono text-xs text-text-muted hover:text-text-primary transition-colors duration-150 hidden"
      aria-label="Clear search"
    >✕</button>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.search-filter').forEach(container => {
    const uid = container.id;
    const listId = container.dataset.listId!;
    const input = document.getElementById(`${uid}-input`) as HTMLInputElement | null;
    const clearBtn = document.getElementById(`${uid}-clear`);
    const list = document.getElementById(listId);
    if (!list || !input || !clearBtn) return;

    const emptyMsg = document.createElement('p');
    emptyMsg.className = 'font-mono text-sm text-text-muted text-center py-12';
    emptyMsg.textContent = 'No results found.';
    emptyMsg.style.display = 'none';
    list.after(emptyMsg);

    function applyFilter() {
      const query = input!.value.trim().toLowerCase();
      const items = list!.querySelectorAll<HTMLElement>('[data-search-text]');
      let visibleCount = 0;

      items.forEach(item => {
        const text = (item.getAttribute('data-search-text') || '').toLowerCase();
        const show = !query || text.includes(query);
        item.style.display = show ? '' : 'none';
        if (show) visibleCount++;
      });

      list!.querySelectorAll<HTMLElement>('[data-search-section]').forEach(section => {
        const hasVisible = Array.from(section.querySelectorAll<HTMLElement>('[data-search-text]'))
          .some(el => el.style.display !== 'none');
        section.style.display = hasVisible ? '' : 'none';
      });

      emptyMsg.style.display = visibleCount === 0 ? '' : 'none';
      clearBtn!.classList.toggle('hidden', !query);
    }

    input.addEventListener('input', applyFilter);

    clearBtn.addEventListener('click', () => {
      input!.value = '';
      applyFilter();
      input!.focus();
    });
  });
</script>
